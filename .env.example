# Copy this file to .env.local for local development
# Set both variables as Environment Variables in your Vercel project settings

# Full n8n webhook URL (kept server-side — never exposed to the browser)
N8N_WEBHOOK_URL=https://salesops.wpseoai.com/webhook/askNotion

# Secret added as X-Api-Key header on every n8n request.
# Set the same value in your n8n Header Auth credential and attach it to the webhook node.
API_SECRET=your-strong-secret-here

# Shared password users must enter to access the chatbot.
# Validated server-side — not exposed in the browser bundle.
FRONTEND_PASSWORD=your-team-password-here
